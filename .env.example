# ---------------------------------------------------------------------------
# DataForSEO API credentials (Basic Auth - see https://app.dataforseo.com/api-access)
# Not required when USE_MOCK_API=true.
# ---------------------------------------------------------------------------
DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here
DATAFORSEO_BASE_URL=https://api.dataforseo.com

# ---------------------------------------------------------------------------
# Local testing mode: when true, no network calls are made. Search Volume and
# Google Trends data is fabricated locally so the pipeline can be exercised
# end-to-end without spending API credits. Never leave this on in production.
# ---------------------------------------------------------------------------
USE_MOCK_API=false

# ---------------------------------------------------------------------------
# File paths
# ---------------------------------------------------------------------------
INPUT_FILE_PATH=data/input/products.xlsx
OUTPUT_DIR=data/output

# ---------------------------------------------------------------------------
# HTTP / retry behaviour
# ---------------------------------------------------------------------------
REQUEST_TIMEOUT_SECONDS=30
RETRY_COUNT=3
RETRY_BACKOFF_SECONDS=2

# ---------------------------------------------------------------------------
# DataForSEO task queue polling (Standard/task_post + task_get mode)
# ---------------------------------------------------------------------------
TASK_POLL_INTERVAL_SECONDS=10
TASK_MAX_WAIT_SECONDS=180

# ---------------------------------------------------------------------------
# Default market targeting (DataForSEO location/language codes)
# 2840 = United States, "en" = English
# ---------------------------------------------------------------------------
DEFAULT_LOCATION_CODE=2840
DEFAULT_LANGUAGE_CODE=en

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
